{
  "name": "@tjakoen/proof",
  "version": "0.1.0",
  "description": "PROOF — the AI plan board: plans-as-markdown (plans/*.md) rendered as a kanban projection. The files are the source of truth; the board never writes.",
  "type": "module",
  "bin": {
    "proof": "./cli.ts"
  },
  "license": "Apache-2.0",
  "author": "Tjakoen Stolk <tjakoen.s@gmail.com> (https://tjakoen.github.io)",
  "homepage": "https://tjakoen.github.io/proof",
  "dependencies": {
    "@tjakoen/batch": "github:tjakoen/batch#d13d361",
    "@tjakoen/grain": "github:tjakoen/grain#599f7d9",
    "@tjakoen/mill": "github:tjakoen/mill#c767085"
  },
  "exports": {
    "./routes.ts": "./routes.ts",
    "./live.ts": "./live.ts",
    "./init.ts": "./init.ts",
    "./serve.ts": "./serve.ts",
    "./check.ts": "./check.ts",
    "./loader.ts": "./loader.ts",
    "./board.css": "./board.css",
    "./board-live.js": "./board-live.js",
    "./core/*": "./core/*",
    "./PLAN.md": "./PLAN.md"
  },
  "files": [
    "core",
    "example",
    "routes.ts",
    "live.ts",
    "init.ts",
    "serve.ts",
    "check.ts",
    "loader.ts",
    "board.ts",
    "board.css",
    "board-live.js",
    "cli.ts",
    "PLAN.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "bun test",
    "deps:refresh": "for p in batch grain mill; do bun add @tjakoen/$p@github:tjakoen/$p#$(git ls-remote https://github.com/tjakoen/$p.git main | cut -c1-7); done"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "bun-types": "^1.3.14",
    "typescript": "^5.8.0"
  }
}
